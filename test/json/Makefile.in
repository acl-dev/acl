CC = $(ENV_CC)

CFLAGS = -c -g -W -Wall -Wcast-qual \
-Waggregate-return \
-Wno-long-long \
-Wmissing-prototypes \
-Wpointer-arith \
-Werror \
-Wshadow \
-D_REENTRANT \
-D_POSIX_PTHREAD_SEMANTICS \
-D_USE_FAST_MACRO
#-Wno-invalid-source-encoding

# -Wcast-align
#CFLAGS = -c -g -W -Wall -Wcast-qual -Wcast-align \
#-Waggregate-return -Wmissing-prototypes \
#-Wpointer-arith -Werror -Wshadow -O2 \
#-D_POSIX_PTHREAD_SEMANTICS -D_USE_FAST_MACRO
###########################################################
#Check system:
#       Linux, SunOS, Solaris, BSD variants, AIX, HP-UX
SYSLIB = -lpthread
CHECKSYSRES = @echo "Unknow system type!";exit 1
UNIXNAME = $(shell uname -sm)

ifeq ($(CC),)
        CC = gcc
endif

ifeq ($(findstring gcc, $(CC)), gcc)
	CFLAGS += -Wstrict-prototypes
endif

ifeq ($(findstring clang, $(CC)), clang)
	CFLAGS += -Wstrict-prototypes \
		  -Wno-invalid-source-encoding \
		  -Wno-invalid-offsetof
endif

ifeq ($(findstring clang++, $(CC)), clang)
	CFLAGS += -Wno-invalid-source-encoding \
		  -Wno-invalid-offsetof
endif

ifeq ($(findstring gcc, $(CC)), clang++)
	CFLAGS += -Wstrict-prototypes \
		  -Wno-invalid-source-encoding \
		  -Wno-invalid-offsetof
endif

ifeq ($(findstring cosmocc, $(CC)), cosmocc)
	CFLAGS += -DCOSMOCC
	CFLAGS += -Wno-implicit-fallthrough
	CFLAGS += -DLINUX2

endif

# For FreeBSD
ifeq ($(findstring FreeBSD, $(UNIXNAME)), FreeBSD)
	CFLAGS += -DFREEBSD
	SYSLIB += -lcrypt -rdynamic
endif

# For Darwin
ifeq ($(findstring Darwin, $(UNIXNAME)), Darwin)
#	CC += -arch x86_64 -arch arm64
	CFLAGS += -DMACOSX -Wno-invalid-source-encoding \
		  -Wno-invalid-offsetof
	SYSLIB += -rdynamic
	UNIXTYPE = MACOSX
endif

#Path for Linux
ifeq ($(findstring Linux, $(UNIXNAME)), Linux)
#	CFLAGS += -DLINUX2
	SYSLIB += -lcrypt -rdynamic
endif

# For CYGWIN
ifeq ($(findstring CYGWIN, $(UNIXNAME)), CYGWIN)
	CFLAGS += -DLINUX2 -DMINGW
	SYSLIB  = -lpthread -rdynamic
	UNIXTYPE = LINUX
endif

# For MINGW
ifeq ($(findstring MINGW, $(UNIXNAME)), MINGW)
	CFLAGS += -DLINUX2 -DMINGW
	SYSLIB  = -lpthread -rdynamic
	UNIXTYPE = LINUX
endif

# For MSYS
ifeq ($(findstring MSYS, $(UNIXNAME)), MSYS)
	CFLAGS += -DLINUX2 -DMINGW
	SYSLIB  = -lpthread -rdynamic
	UNIXTYPE = LINUX
endif

#Path for SunOS
ifeq ($(findstring SunOS, $(UNIXNAME)), SunOS)
	ifeq ($(findstring 86, $(UNIXNAME)), 86)
		SYSLIB += -lsocket -lnsl -lrt
	endif
	ifeq ($(findstring sun4u, $(UNIXNAME)), sun4u)
		SYSLIB += -lsocket -lnsl -lrt
	endif
	CFLAGS += -DSUNOS5
	SYSLIB += -lcrypt -rdynamic
endif

#Path for HP-UX
ifeq ($(findstring HP-UX, $(UNIXNAME)), HP-UX)
	CFLAGS += -DHP_UX -DHPUX11
	PLAT_NAME=hp-ux
	SYSLIB += -lcrypt -rdynamic
endif

#Find system type.
ifneq ($(SYSPATH),)
	CHECKSYSRES = @echo "System is $(shell uname -sm)"
endif
###########################################################

BASE_PATH =
ifneq ($(base_path),)
	BASE_PATH = $(base_path)
else
	BASE_PATH = ../../lib_acl
endif

#ACL_PATH   = ../../../lib_acl
ACL_PATH   = $(BASE_PATH)
ACL_INC    = $(ACL_PATH)/include
ACL_LIB    = $(ACL_PATH)/lib

EXTLIBS =
CFLAGS += -I$(ACL_INC)
LDFLAGS = -L$(ACL_LIB) -Wl,-rpath,$(ACL_LIB) -lacl $(EXTLIBS) $(SYSLIB)

###########################################################

OUT_PATH = .
OBJ_PATH = $(OUT_PATH)

#Project's objs and programs
SRC = $(wildcard *.c)
# 从源文件列表生成要编译的程序（排除临时测试文件 te*.c）
PROGRAMS ?= $(patsubst %.c, %, $(filter-out te%.c, $(SRC)))
###########################################################

.PHONY = all clean
COMPILE = $(CC) $(CFLAGS)

# 默认目标：编译所有程序
all: $(PROGRAMS)
	@echo ""
	@echo "All ok! Output: $(PROGRAMS)"
	@echo ""

# 编译链接规则：从 .c 文件直接生成可执行文件
# 注意：去掉 -c 标志，使用 LDFLAGS 来进行链接
%: %.c
	$(CC) $(filter-out -c, $(CFLAGS)) $< $(LDFLAGS) -o $(OBJ_PATH)/$@

RM:
	rm -f $(PROGRAMS) $(patsubst %, $(OBJ_PATH)/%, $(PROGRAMS))

clean:
	rm -f $(PROGRAMS) $(patsubst %, $(OBJ_PATH)/%, $(PROGRAMS))
###########################################################
